#!/usr/bin/env bash
set -euo pipefail

workDir=$(dirname "$0")
cd "$workDir" # cd to directory with flake

if [ "${1:-}" = "pull" ]; then
    nix flake update
    if [ "${2:-}" = "--all" ]; then
        cd ./home-nix/programs/node-packages && ./update-node-pkgs
    fi
else
    if [ "${1:-}" = "plain" ]; then
        nix run -L home-manager -- --impure --flake ".#$(hostname -s)" "$@"
    elif command -v nom > /dev/null; then
        nix run -L home-manager -- --impure --flake ".#$(hostname -s)" "$@" |& nom
    else
        nix run -L home-manager -- --impure --flake ".#$(hostname -s)" "$@"
    fi
fi
